# Ghostty 配置 — 改完按 cmd+shift+, 热重载
# 所有可用选项见:https://ghostty.org/docs/config/reference

# ── 主题与外观 ──────────────────────────────
# 跟随系统亮暗自动切换(ghostty +list-themes 预览全部)
window-theme = system

font-family = "JetBrainsMono Nerd Font Mono"
font-size = 14
# mac 上字体描边更清晰
font-thicken = true

# 轻微透明 + 背后毛玻璃模糊
background-opacity = 0.95
background-blur = 20
# 内容和窗口边缘留白
window-padding-x = 8
window-padding-y = 6
# 用广色域,颜色更鲜
window-colorspace = display-p3

# 标签页风格更原生紧凑
macos-titlebar-style = tabs

# ── 选中 / 复制 / 鼠标 ───────────────────────
# 选中即复制
copy-on-select = clipboard
mouse-hide-while-typing = true
# 粘贴含危险控制字符时弹确认
clipboard-paste-protection = true
# 复制时去掉行尾空格,粘代码更干净
clipboard-trim-trailing-spaces = true

# ── 光标 ────────────────────────────────────
cursor-style = block
cursor-style-blink = false

# ── 行为 ────────────────────────────────────
# 关闭窗口不弹确认
confirm-close-surface = false
# 退出时记住窗口
window-save-state = always
# 左 Option 当 Alt,右 Option 保留特殊字符输入
macos-option-as-alt = left
# 回滚缓冲(约 10MB),默认偏小
scrollback-limit = 10000000
# shell 集成增强:光标跟随、sudo 提示、自动改标题
shell-integration-features = cursor,sudo,title
# 改窗口大小时不弹尺寸浮层
resize-overlay = never
# 新标签开在最右边
window-new-tab-position = end

# 未聚焦的分屏稍微变暗,一眼看出焦点在哪(默认 0.7)
unfocused-split-opacity = 0.7

# Claude Code / 部分 CLI 需要 shift+enter 换行不提交
keybind = shift+enter=text:\n

# ── 全局下拉终端(Quick Terminal)──────────────
# cmd+` 全局唤出/隐藏,即使 Ghostty 没在前台也生效
keybind = global:cmd+grave_accent=toggle_quick_terminal
# 从屏幕顶部下拉(top/bottom/left/right/center)
quick-terminal-position = top
