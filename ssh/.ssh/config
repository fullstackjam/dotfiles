# SSH Client Configuration

# Global settings
Host *
    ServerAliveInterval 30
    StrictHostKeyChecking no
    UserKnownHostsFile=/dev/null
    ControlMaster auto
    ControlPath ~/.ssh/%r@%h:%p

# GitHub configuration
Host github.com
    HostName ssh.github.com
    PreferredAuthentications publickey
    User git
    port 443
